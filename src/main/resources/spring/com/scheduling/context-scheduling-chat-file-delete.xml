<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
          http://www.springframework.org/schema/beans
          http://www.springframework.org/schema/beans/spring-beans-4.0.xsd">

    <!-- Dashboard category trend batch (Quartz) -->
	<bean id="chatFileBatchJob" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<property name="targetObject" ref="chatFileDeleteBatchService"/>
		<property name="targetMethod" value="deleteBatchAuto"/>
		<property name="concurrent" value="false"/>
	</bean>

	<bean id="chatFileDeleteBatchTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
		<property name="jobDetail" ref="chatFileBatchJob"/>
		<property name="cronExpression" value="0 05 15 * * ?"/>
	</bean>

	<bean id="dashBoardScheduler" class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
		<property name="triggers">
			<list>
				<ref bean="chatFileDeleteBatchTrigger"/>
			</list>
		</property>
	</bean>

</beans>
