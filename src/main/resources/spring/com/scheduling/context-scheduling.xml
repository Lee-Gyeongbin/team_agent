<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
          http://www.springframework.org/schema/beans
          http://www.springframework.org/schema/beans/spring-beans-4.0.xsd">

    <!-- 대시보드 카테고리 통계 배치 (Quartz) -->
	<bean id="dashBoardCategoryTrendJobDetail" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<property name="targetObject" ref="dashBoardServiceImpl"/>
		<property name="targetMethod" value="buildYesterdayCategoryTrend"/>
		<property name="concurrent" value="false"/>
	</bean>

	<bean id="dashBoardCategoryTrendTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
		<property name="jobDetail" ref="dashBoardCategoryTrendJobDetail"/>
		<property name="cronExpression" value="0 10 0 * * ?"/>
	</bean>

    <!-- 표준지역코드 캐시 갱신 배치 (Quartz) -->
	<bean id="regionTreeRefreshJobDetail" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<property name="targetObject" ref="regionTreeServiceImpl"/>
		<property name="targetMethod" value="refreshRegionTreeCache"/>
		<property name="concurrent" value="false"/>
	</bean>

	<bean id="regionTreeRefreshTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
		<property name="jobDetail" ref="regionTreeRefreshJobDetail"/>
		<property name="cronExpression" value="0 20 0 1 * ?"/>
	</bean>

	<!-- 채팅 첨부파일 삭제 배치 (Quartz) -->
	<bean id="chatFileBatchJob" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<property name="targetObject" ref="chatFileDeleteBatchService"/>
		<property name="targetMethod" value="deleteBatchAuto"/>
		<property name="concurrent" value="false"/>
	</bean>

	<bean id="chatFileDeleteBatchTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
		<property name="jobDetail" ref="chatFileBatchJob"/>
		<property name="cronExpression" value="0 30 0 * * ?"/>
	</bean>

	<!-- 카테고리 -> 키워드 교체 예정 -->
	<!-- 대시보드 전날 채팅 키워드 통계 배치 (Quartz) -->
	<bean id="dashBoardKeywordDailyStatJobDetail" class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<property name="targetObject" ref="dashBoardServiceImpl"/>
		<property name="targetMethod" value="buildYesterdayKeywordDailyStat"/>
		<property name="concurrent" value="false"/>
	</bean>

	<bean id="dashBoardKeywordDailyStatTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
		<property name="jobDetail" ref="dashBoardKeywordDailyStatJobDetail"/>
		<property name="cronExpression" value="0 50 0 * * ?"/>
	</bean>

	<bean id="dashBoardScheduler" class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
		<property name="triggers">
			<list>
				<ref bean="dashBoardCategoryTrendTrigger"/>
				<ref bean="dashBoardKeywordDailyStatTrigger"/>
				<ref bean="regionTreeRefreshTrigger"/>
				<ref bean="chatFileDeleteBatchTrigger"/>
			</list>
		</property>
	</bean>

</beans>
